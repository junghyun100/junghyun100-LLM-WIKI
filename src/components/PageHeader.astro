---
// PageHeader.astro - Custom page header with Layer Badge Strip + Reading Mode toggle
---
import type { Props } from '@astrojs/starlight/components';
import { Slots } from '@astrojs/starlight/components';
import SearchFilterInjector from './SearchFilterInjector.astro';

const { page, locale } = Astro.props as Props;

// Parse layer/type/date from page
function getPageMeta(page: Props['page']) {
  const slug = page.url.split('/').filter(Boolean).pop() || '';
  const parts = slug.split('-');

  // Date: YYYY-MM-DD prefix
  const dateMatch = slug.match(/^(\d{4}-\d{2}-\d{2})/);
  const date = dateMatch ? dateMatch[1] : null;

  // Layer from directory structure
  let layer: 'source' | 'wiki' | 'schema' | 'xref' = 'wiki';
  if (page.url.includes('/sources/')) layer = 'source';
  else if (page.url.includes('/schema/')) layer = 'schema';
  else if (page.url.includes('/wiki/')) layer = 'wiki';

  // Type from directory or frontmatter
  let type = 'page';
  if (page.url.includes('/entities/')) type = 'entity';
  else if (page.url.includes('/concepts/')) type = 'concept';
  else if (page.url.includes('/synthesis/')) type = 'synthesis';
  else if (page.url.includes('/comparisons/')) type = 'comparison';
  else if (page.url.includes('/sources/')) type = 'source';
  else if (page.url.includes('/templates/')) type = 'template';
  else if (page.url.includes('/prompts/') || page.url.includes('/prompts/')) type = 'prompt';
  else if (page.url.includes('/schema/')) type = 'rule';

  return { layer, type, date, slug };
}

const { layer, type, date } = getPageMeta(page);

const layerLabels: Record<string, string> = {
  source: 'SOURCES',
  wiki: 'WIKI',
  schema: 'SCHEMA',
  xref: 'XREF'
};

const typeLabels: Record<string, string> = {
  entity: 'ENTITY',
  concept: 'CONCEPT',
  synthesis: 'SYNTHESIS',
  comparison: 'COMPARISON',
  source: 'SOURCE',
  template: 'TEMPLATE',
  rule: 'RULE',
  prompt: 'PROMPT',
  page: 'PAGE'
};
---

<script>
  // Reading mode toggle logic
  if (typeof window !== 'undefined') {
    const toggle = document.querySelector('.wiki-reading-toggle') as HTMLButtonElement;
    const html = document.documentElement;

    // Restore from localStorage
    const saved = localStorage.getItem('wiki-reading-mode');
    if (saved === 'true') {
      html.classList.add('wiki-reading-mode');
      if (toggle) toggle.setAttribute('aria-pressed', 'true');
    }

    toggle?.addEventListener('click', () => {
      const enabled = html.classList.toggle('wiki-reading-mode');
      toggle.setAttribute('aria-pressed', String(enabled));
      localStorage.setItem('wiki-reading-mode', String(enabled));
    });
  }
</script>

<header class="wiki-page-header">
  <div class="wiki-layer-strip" role="status" aria-live="polite">
    <span class="wiki-layer-badge" data-layer={layer}>{layerLabels[layer] || layer.toUpperCase()}</span>
    <span class="wiki-layer-badge" data-layer={layer}>{typeLabels[type] || type.toUpperCase()}</span>
    {date && <span class="wiki-date-badge">{date}</span>}
  </div>

  <div class="wiki-page-header__content">
    <h1 class="wiki-page-title">{page.title}</h1>
    {page.description && <p class="wiki-page-description">{page.description}</p>}

    <div class="wiki-page-header__actions">
      <button
        class="wiki-reading-toggle"
        aria-pressed="false"
        aria-label="읽기 모드 토글"
        title="읽기 모드 (사이드바 숨김, 넓은 폭, 큰 글자)"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" aria-hidden="true">
          <path d="M4 9h16M4 15h16M4 21h16" strokeLinecap="round"/>
        </svg>
        <span>읽기 모드</span>
      </button>

      <Slots name="page-header-actions" />
    </div>
  </div>
</header>

<!-- Search filter injector (hydrates when search dialog opens) -->
<SearchFilterInjector client:visible />

<style>
  .wiki-page-header {
    padding: var(--wiki-space-6) 0 var(--wiki-space-4);
    border-bottom: 1px solid var(--wiki-border);
    margin-bottom: var(--wiki-space-8);
  }

  .wiki-layer-strip {
    margin-bottom: var(--wiki-space-6);
    padding-bottom: var(--wiki-space-4);
    border-bottom: 1px solid var(--wiki-border);
  }

  .wiki-page-header__content {
    max-width: var(--wiki-content-max);
    margin: 0 auto;
    padding: 0 var(--wiki-space-4);
  }

  .wiki-page-title {
    font-size: var(--wiki-text-2xl);
    font-weight: 700;
    line-height: var(--wiki-leading-tight);
    letter-spacing: var(--wiki-tracking-tight);
    color: var(--color-primary);
    margin: 0 0 var(--wiki-space-3);
  }

  .wiki-page-description {
    font-size: var(--wiki-text-lg);
    line-height: var(--wiki-leading-relaxed);
    color: var(--wiki-text-muted);
    margin: 0 0 var(--wiki-space-6);
    max-width: 60ch;
  }

  .wiki-page-header__actions {
    display: flex;
    align-items: center;
    gap: var(--wiki-space-3);
    flex-wrap: wrap;
  }

  .wiki-reading-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--wiki-space-2);
    padding: var(--wiki-space-2) var(--wiki-space-3);
    background: var(--wiki-surface);
    border: 1px solid var(--wiki-border);
    border-radius: var(--wiki-radius-md);
    font-size: var(--wiki-text-sm);
    font-weight: 500;
    color: var(--wiki-text);
    cursor: pointer;
    transition: all var(--wiki-duration-fast) var(--wiki-ease);
  }
  .wiki-reading-toggle:hover {
    background: var(--wiki-gray-100);
    border-color: var(--wiki-border-strong);
  }
  @media (prefers-color-scheme: dark) {
    .wiki-reading-toggle:hover { background: var(--wiki-gray-800); }
  }
  .wiki-reading-toggle:focus-visible {
    outline: none;
    box-shadow: var(--wiki-focus-ring);
  }
  .wiki-reading-toggle[aria-pressed="true"] {
    background: var(--wiki-layer-wiki-bg);
    border-color: var(--wiki-layer-wiki-border);
    color: var(--wiki-layer-wiki);
  }
  .wiki-reading-toggle svg { flex-shrink: 0; }

  @media (max-width: 768px) {
    .wiki-page-title { font-size: var(--wiki-text-2xl); }
    .wiki-page-description { font-size: var(--wiki-text-base); }
    .wiki-reading-toggle span { display: none; }
  }
</style>