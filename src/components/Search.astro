---
/**
 * Custom Search component that wraps Starlight's Search and adds filter chips
 * Overrides the default Starlight Search component via config.components.Search
 */
import StarlightSearch from '@astrojs/starlight/components/Search.astro';
---
<StarlightSearch />

<script is:inline>
  // Inject filter chips into the search dialog when it opens
  function injectSearchFilter() {
    // Check if filter already injected
    if (document.querySelector('.wiki-search-filters')) return;

    const searchContainer = document.querySelector('#starlight__search');
    if (!searchContainer) return;

    // Create filter UI
    const filterHTML = `
      <div class="wiki-search-filters" role="group" aria-label="검색 결과 필터">
        <div class="wiki-search-filter" role="tablist" aria-label="레이어 필터">
          <button class="wiki-filter-chip wiki-filter-chip--none wiki-filter-chip--active" role="tab" aria-selected="true" data-filter-type="layer" data-filter-value="" data-filter-id="all" tabindex="0">전체</button>
          <button class="wiki-filter-chip wiki-filter-chip--teal" role="tab" aria-selected="false" data-filter-type="layer" data-filter-value="source" data-filter-id="layer-source" tabindex="-1">Sources</button>
          <button class="wiki-filter-chip wiki-filter-chip--blue" role="tab" aria-selected="false" data-filter-type="layer" data-filter-value="wiki" data-filter-id="layer-wiki" tabindex="-1">Wiki</button>
          <button class="wiki-filter-chip wiki-filter-chip--violet" role="tab" aria-selected="false" data-filter-type="layer" data-filter-value="schema" data-filter-id="layer-schema" tabindex="-1">Schema</button>
        </div>
        <div class="wiki-search-filter" role="tablist" aria-label="타입 필터">
          <button class="wiki-filter-chip wiki-filter-chip--blue" role="tab" aria-selected="false" data-filter-type="type" data-filter-value="entity" data-filter-id="type-entity" tabindex="-1">Entities</button>
          <button class="wiki-filter-chip wiki-filter-chip--violet" role="tab" aria-selected="false" data-filter-type="type" data-filter-value="concept" data-filter-id="type-concept" tabindex="-1">Concepts</button>
          <button class="wiki-filter-chip wiki-filter-chip--teal" role="tab" aria-selected="false" data-filter-type="type" data-filter-value="source" data-filter-id="type-source" tabindex="-1">Sources</button>
        </div>
        <span class="wiki-search-filter__count" aria-live="polite"></span>
      </div>
    `;

    // Insert filter at the beginning of search container
    searchContainer.insertAdjacentHTML('afterbegin', filterHTML);

    // Initialize filter controller
    new SearchFilterController();
  }

  // Search filter controller class
  class SearchFilterController {
    activeLayer = '';
    activeType = '';
    chips = [];
    observer = null;
    debounceTimer = null;

    constructor() {
      this.chips = Array.from(document.querySelectorAll('.wiki-filter-chip'));
      this.restoreFromHash();
      this.bindKeys();
      this.bindClicks();
      this.observePagefindResults();
      this.updateChipStates();
    }

    bindClicks() {
      this.chips.forEach(chip => {
        chip.addEventListener('click', () => this.toggleFilter(chip));
      });
    }

    bindKeys() {
      document.addEventListener('keydown', e => {
        if (!this.isChipFocused()) return;

        const activeIndex = this.chips.findIndex(c => c === document.activeElement);
        if (activeIndex === -1) return;

        let nextIndex = activeIndex;
        const isLayerGroup = this.chips[activeIndex].dataset.filterType === 'layer';
        const groupChips = this.chips.filter(c => c.dataset.filterType === (isLayerGroup ? 'layer' : 'type'));

        switch (e.key) {
          case 'ArrowRight':
          case 'ArrowDown':
            e.preventDefault();
            nextIndex = this.chips.indexOf(groupChips[(groupChips.indexOf(this.chips[activeIndex]) + 1) % groupChips.length]);
            break;
          case 'ArrowLeft':
          case 'ArrowUp':
            e.preventDefault();
            nextIndex = this.chips.indexOf(groupChips[(groupChips.indexOf(this.chips[activeIndex]) - 1 + groupChips.length) % groupChips.length]);
            break;
          case 'Home':
            e.preventDefault();
            nextIndex = this.chips.indexOf(groupChips[0]);
            break;
          case 'End':
            e.preventDefault();
            nextIndex = this.chips.indexOf(groupChips[groupChips.length - 1]);
            break;
          case 'Enter':
          case ' ':
            e.preventDefault();
            this.toggleFilter(this.chips[activeIndex]);
            return;
          default:
            return;
        }

        this.chips[nextIndex]?.focus();
      });
    }

    isChipFocused() {
      return this.chips.some(c => c === document.activeElement);
    }

    toggleFilter(chip) {
      const type = chip.dataset.filterType;
      const value = chip.dataset.filterValue || '';

      if (type === 'layer') {
        this.activeLayer = this.activeLayer === value ? '' : value;
        this.updateChipStates('layer');
      } else {
        this.activeType = this.activeType === value ? '' : value;
        this.updateChipStates('type');
      }

      this.applyFilter();
      this.updateHash();
    }

    updateChipStates(filterType) {
      this.chips.forEach(chip => {
        const type = chip.dataset.filterType;
        const value = chip.dataset.filterValue || '';

        if (filterType && type !== filterType) return;

        const isActive =
          (type === 'layer' && value === this.activeLayer) ||
          (type === 'type' && value === this.activeType) ||
          (type === 'layer' && value === '' && this.activeLayer === '');

        chip.classList.toggle('wiki-filter-chip--active', isActive);
        chip.setAttribute('aria-selected', isActive.toString());
        chip.setAttribute('aria-pressed', isActive.toString());
      });
    }

    applyFilter() {
      if (this.debounceTimer) clearTimeout(this.debounceTimer);
      this.debounceTimer = window.setTimeout(() => this.filterPagefindResults(), 50);
    }

    filterPagefindResults() {
      const results = document.querySelectorAll('#starlight__search .pagefind-ui__result');
      const nestedResults = document.querySelectorAll('#starlight__search .pagefind-ui__result-nested');
      const allResults = [...results, ...nestedResults];

      allResults.forEach(result => {
        const layer = result.getAttribute('data-layer') || '';
        const type = result.getAttribute('data-type') || '';

        const layerMatch = !this.activeLayer || layer === this.activeLayer;
        const typeMatch = !this.activeType || type === this.activeType;
        const shouldShow = layerMatch && typeMatch;

        (result as HTMLElement).style.display = shouldShow ? '' : 'none';
      });

      this.updateResultCount(allResults);
    }

    updateResultCount(results) {
      const visible = results.filter(r => (r as HTMLElement).style.display !== 'none').length;
      const counter = document.querySelector('.wiki-search-filter__count');
      if (counter) counter.textContent = `${visible}개 결과`;
    }

    observePagefindResults() {
      const searchContainer = document.querySelector('#starlight__search');
      if (!searchContainer) {
        setTimeout(() => this.observePagefindResults(), 100);
        return;
      }

      this.observer = new MutationObserver(() => {
        this.filterPagefindResults();
        this.enrichResultsWithMeta();
      });

      this.observer.observe(searchContainer, {
        childList: true,
        subtree: true,
        attributes: true,
        attributeFilter: ['data-layer', 'data-type'],
      });

      this.enrichResultsWithMeta();
    }

    enrichResultsWithMeta() {
      const results = document.querySelectorAll(
        '#starlight__search .pagefind-ui__result, #starlight__search .pagefind-ui__result-nested'
      );

      results.forEach(result => {
        if (result.hasAttribute('data-layer') && result.hasAttribute('data-type')) return;

        const link = result.querySelector('.pagefind-ui__result-link, .pagefind-ui__result-nested .pagefind-ui__result-link');
        if (!link) return;

        const url = link.getAttribute('href');
        if (!url) return;

        const layerMatch = url.match(/\/ko\/(wiki|schema|sources)\//);
        const layer = layerMatch ? layerMatch[1] : '';

        let type = '';
        if (url.includes('/entities/')) type = 'entity';
        else if (url.includes('/concepts/')) type = 'concept';
        else if (url.includes('/sources/')) type = 'source';

        if (layer === 'wiki' && !type && url.includes('/wiki/')) {
          type = 'entity';
        }

        if (layer) result.setAttribute('data-layer', layer);
        if (type) result.setAttribute('data-type', type);
      });

      this.filterPagefindResults();
    }

    updateHash() {
      const params = new URLSearchParams();
      if (this.activeLayer) params.set('layer', this.activeLayer);
      if (this.activeType) params.set('type', this.activeType);

      const hash = params.toString() ? '?' + params.toString() : '';
      window.history.replaceState(null, '', window.location.pathname + hash);
    }

    restoreFromHash() {
      const params = new URLSearchParams(window.location.search.slice(1));
      this.activeLayer = params.get('layer') || '';
      this.activeType = params.get('type') || '';
    }

    destroy() {
      this.observer?.disconnect();
      if (this.debounceTimer) clearTimeout(this.debounceTimer);
    }
  }

  // Watch for search dialog opening
  const siteSearch = document.querySelector('site-search');
  if (siteSearch) {
    const dialog = siteSearch.querySelector('dialog');
    if (dialog) {
      const observer = new MutationObserver(() => {
        if (dialog.open) {
          injectSearchFilter();
        }
      });
      observer.observe(dialog, { attributes: true, attributeFilter: ['open'] });

      // Check if already open
      if (dialog.open) {
        injectSearchFilter();
      }
    }
  }

  // Also try after DOMContentLoaded in case dialog is already open
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', injectSearchFilter);
  } else {
    injectSearchFilter();
  }
</script>